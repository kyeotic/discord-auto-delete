{
  "$schema": "https://raw.githubusercontent.com/skymethod/denoflare/v0.7.0/common/config.schema.json",
  "scripts": {
    "discord-auto-delete": {
      "path": "src/worker.ts",
      "localPort": 8080,
      "bindings": {
        "BOT_TOKEN": { "secret": "${env:BOT_TOKEN}" },
        "DISCORD_PUBLIC_KEY": { "secret": "${env:DISCORD_PUBLIC_KEY}" },
        "CONFIGS_KV": { "kvNamespace": "a0a0c46e2f83417d85837c591ee33f10" }
      }
    }
  },
  "profiles": {
    "default": {
      "accountId": "${env:CF_ACCOUNT_ID}",
      "apiToken": "${env:CF_API_TOKEN}"
    }
  }
}
